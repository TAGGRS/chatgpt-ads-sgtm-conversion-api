___SANDBOXED_JS_FOR_SERVER___

const sendHttpRequest = require('sendHttpRequest');
const JSON = require('JSON');
const getEventData = require('getEventData');
const getTimestampMillis = require('getTimestampMillis');
const logToConsole = require('logToConsole');

// 1. Configuration & Constants
const apiKey = data.apiKey;
const pixelId = data.pixelId;
const requestUrl = 'https://bzr.openai.com/v1/events?pid=' + pixelId;

// 2. Map Core Event Data
const eventName = data.eventName || getEventData('event_name');
const eventId = data.eventId || getEventData('event_id') || getEventData('transaction_id');
const sourceUrl = data.sourceUrl || getEventData('page_location');
const oppref = data.oppref || getEventData('oppref');

// 3. Build the Event Object
const eventObj = {
  id: eventId,
  type: data.isCustomEvent ? 'custom' : eventName,
  custom_event_name: data.isCustomEvent ? eventName : undefined,
  timestamp_ms: getTimestampMillis(),
  action_source: data.actionSource || 'web',
  source_url: sourceUrl,
  oppref: oppref,
  user: {
    email: data.userEmail || getEventData('user_data.email_address'),
    phone: data.userPhone || getEventData('user_data.phone_number')
  },
  data: {}
};

// 4. Map Flexible Parameters from the Table
if (data.customParams) {
  data.customParams.forEach(param => {
    eventObj.data[param.key] = param.value;
  });
}

// 5. Construct the Full Request Body
const requestBody = {
  validate_only: data.validateOnly || false,
  events: [eventObj]
};

// 6. Send the Request
sendHttpRequest(requestUrl, (statusCode, headers, body) => {
  if (statusCode >= 200 && statusCode < 300) {
    data.gtmOnSuccess();
  } else {
    logToConsole('OpenAI CAPI Error: ' + statusCode + ' - ' + body);
    data.gtmOnFailure();
  }
}, {
  method: 'POST',
  headers: {
    'Authorization': 'Bearer ' + apiKey,
    'Content-Type': 'application/json'
  }
}, JSON.stringify(requestBody));


